# Server Port
PORT=5000

# AI Provider Configuration (Options: gemini, openai)
# Set your preferred provider and its key.
AI_PROVIDER=gemini

# Gemini API Key (Get from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (Optional)
OPENAI_API_KEY=your_openai_api_key_here

# Twilio WhatsApp API (Optional)
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=your_twilio_whatsapp_number_here
TWILIO_TO_NUMBER=your_test_whatsapp_number_here

# WhatsApp Cloud API (Optional - Alternative to Twilio)
WHATSAPP_TOKEN=your_whatsapp_cloud_token_here
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
WHATSAPP_TO_NUMBER=your_test_whatsapp_number_here
